generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  avatar           String?
  stripeCustomerId String?
  plan             String          @default("free")
  role             String          @default("user")
  topics           String[]        @default([])
  onboardingCompleted Boolean      @default(false)
  marketingConsent Boolean         @default(true)
  createdAt        DateTime        @default(now())
  socialAccounts   SocialAccount[]
  posts            Post[]
  savedIdeas       SavedIdea[]
  voiceProfile     VoiceProfile?
  onboardingResponse OnboardingResponse?
}

model SocialAccount {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  accountName  String?
  accountId    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model Post {
  id                   String              @id @default(cuid())
  userId               String
  postType             String              @default("text")
  content              String
  firstComment         String?
  documentTitle        String?
  carouselMode         String?
  carouselSlides       Json?
  carouselDocumentBase64 String?
  coverSlide           Boolean             @default(false)
  platforms            String[]
  status               String              @default("draft")
  voiceScore           Int?
  voiceToneScore       Int?
  voiceRhythmScore     Int?
  voiceWordChoiceScore Int?
  voiceFeedback        String?
  voiceTip             String?
  voiceSignaturePhrases String[]           @default([])
  voiceSafeToPublish   Boolean?
  voiceWeakestSentence String?
  voiceSuggestions     String[]            @default([])
  lastVoiceScoredAt    DateTime?
  scheduledAt          DateTime?
  publishedAt          DateTime?
  errorLog             String?
  publishLeaseId       String?
  publishLeaseExpiresAt DateTime?
  createdAt            DateTime            @default(now())
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries           PostDelivery[]
  publishAttempts      PostPublishAttempt[]

  @@index([status, scheduledAt])
}

model PostDelivery {
  id           String   @id @default(cuid())
  postId       String
  platform     String
  status       String   @default("pending")
  externalPostId String?
  metadata     Json?
  publishedAt  DateTime?
  errorLog     String?
  attemptCount Int      @default(0)
  lastAttemptAt DateTime?
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
  @@index([postId, status])
}

model PostPublishAttempt {
  id          String   @id @default(cuid())
  postId      String
  platform    String
  trigger     String
  claimId     String
  status      String
  errorLog    String?
  createdAt   DateTime @default(now())
  completedAt DateTime?
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model VoiceProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  setupSource    String   @default("linkedin_posts")
  foundationKey  String?
  samplePosts    String[]
  traits         String[]
  dimensions     Json?
  sentenceLength String?
  formality      String?
  usesQuestions  Boolean  @default(false)
  usesLists      Boolean  @default(false)
  summary        String?
  lastAnalyzedAt DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OnboardingResponse {
  id               String   @id @default(cuid())
  userId           String   @unique
  useCase          String
  postingFreq      String
  email            String?
  marketingConsent Boolean  @default(true)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedIdea {
  id        String   @id @default(cuid())
  userId    String
  hook      String
  expansion String
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
