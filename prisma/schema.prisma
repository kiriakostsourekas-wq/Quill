generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  avatar           String?
  stripeCustomerId String?
  plan             String          @default("free")
  createdAt        DateTime        @default(now())
  socialAccounts   SocialAccount[]
  posts            Post[]
  voiceProfile     VoiceProfile?
}

model SocialAccount {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  accountName  String?
  accountId    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model Post {
  id                   String              @id @default(cuid())
  userId               String
  content              String
  platforms            String[]
  status               String              @default("draft")
  voiceScore           Int?
  voiceFeedback        String?
  voiceTip             String?
  voiceWeakestSentence String?
  voiceSuggestions     String[]            @default([])
  lastVoiceScoredAt    DateTime?
  scheduledAt          DateTime?
  publishedAt          DateTime?
  errorLog             String?
  publishLeaseId       String?
  publishLeaseExpiresAt DateTime?
  createdAt            DateTime            @default(now())
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries           PostDelivery[]
  publishAttempts      PostPublishAttempt[]

  @@index([status, scheduledAt])
}

model PostDelivery {
  id           String   @id @default(cuid())
  postId       String
  platform     String
  status       String   @default("pending")
  externalPostId String?
  metadata     Json?
  publishedAt  DateTime?
  errorLog     String?
  attemptCount Int      @default(0)
  lastAttemptAt DateTime?
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
  @@index([postId, status])
}

model PostPublishAttempt {
  id          String   @id @default(cuid())
  postId      String
  platform    String
  trigger     String
  claimId     String
  status      String
  errorLog    String?
  createdAt   DateTime @default(now())
  completedAt DateTime?
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model VoiceProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  samplePosts    String[]
  traits         String[]
  sentenceLength String?
  formality      String?
  usesQuestions  Boolean  @default(false)
  usesLists      Boolean  @default(false)
  summary        String?
  lastAnalyzedAt DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
