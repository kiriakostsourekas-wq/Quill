NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
GROQ_API_KEY=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Official LinkedIn post import is optional and usually requires restricted
# r_member_social approval. Keep both false unless that permission is approved.
LINKEDIN_READ_POSTS_ENABLED=false
NEXT_PUBLIC_LINKEDIN_READ_POSTS_ENABLED=false
LINKEDIN_API_VERSION=202602
# X OAuth 2.0 client credentials from the X Developer Portal app settings.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard -> Product catalog -> open each product -> copy the Price ID.
STRIPE_SOLO_PRICE_ID=
STRIPE_PRO_PRICE_ID=
RESEND_API_KEY=
ENCRYPTION_KEY=
# Used by the external HTTP scheduler that calls /api/cron/publish. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
# Enables text-post scheduling in the UI/API after an authenticated external scheduler is active.
# Keep false in environments where no scheduler is sending Authorization: Bearer $CRON_SECRET.
NEXT_PUBLIC_AUTO_SCHEDULING_ENABLED=false
NEXT_PUBLIC_APP_URL=https://quill-ai.dev
